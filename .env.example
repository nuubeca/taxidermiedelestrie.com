# Supabase — Shared Connection Pooler (runtime)
# Format: postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR-PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Connexion directe via Shared Pooler (port 5432) — utilisée par Prisma pour les migrations.
# Obligatoire si DATABASE_URL pointe vers pgbouncer.
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR-PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# Chemin vers le dump JSON phpMyAdmin (relatif au dossier app/)
DUMP_JSON_PATH="../mouldec_wp.json"

# Site WordPress source — utilisé par 03-download-media.ts (non exécuté par défaut)
WP_SITE_URL="https://taxidermiedelestrie.com"

# Destination des médias téléchargés
MEDIA_DOWNLOAD_DIR="./public/uploads"
